          "description": null,
          "method": "POST",
          "headers": {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          "body": {
            "filters": {
              "keywords": [
                "{{key_words}}"
              ],
              "time_period": [
                {
                  "start_date": "\"{{start_date}}\"",
                  "end_date": "\"{{end_date}}\""
                }
              ],
              "award_type_codes": [
                "10", "06"
              ]
            },
            "page": "{{page}}",
            "limit": "{{page_length}}",
            "sort": "Award Amount",
            "order": "desc",
            "auditTrail": "Results Table - Spending by award search",
            "fields": [
